{
    "name": "prototype",
    "private": true,
    "workspaces": ["frontend", "backend"],
    "scripts": {
        "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev -w frontend\" \"npm run dev -w backend\"",
        "build": "npm run build --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "preview": "npm run preview --workspaces --if-present"
    },

    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "concurrently": "^9.1.2",
        "eslint": "^10.3.0",
        "globals": "^17.6.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.59.2"
    }
}